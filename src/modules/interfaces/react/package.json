{
  "name": "cyber-autoagent-cli",
  "version": "0.8.1",
  "description": "Cyber-AutoAgent CLI with React + Ink",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "cyber-react": "./dist/index.js",
    "cyber-native": "./dist/index-native.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "start": "node --expose-gc --max-old-space-size=6144 dist/index.js",
    "dev": "node --expose-gc --max-old-space-size=6144 --loader tsx src/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config tests/jest.config.cjs",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --config tests/jest.config.cjs --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --config tests/jest.config.cjs --coverage",
    "test:setup": "NODE_OPTIONS=--experimental-vm-modules jest --config tests/jest.config.cjs setup.test.tsx",
    "test:operations": "NODE_OPTIONS=--experimental-vm-modules jest --config tests/jest.config.cjs operation-flow.test.tsx",
    "test:visual": "NODE_OPTIONS=--experimental-vm-modules jest --config tests/jest.config.cjs visual-regression.test.tsx",
    "test:journeys": "NODE_OPTIONS=--experimental-vm-modules jest --config tests/jest.config.cjs --verbose",
    "test:all": "npm run build && npm run test:coverage",
    "validate": "npm run build && npm run test:all"
  },
  "dependencies": {
    "ansi-escapes": "^7.0.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.2",
    "dockerode": "^4.0.9",
    "ink": "^6.8.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "ink-link": "^5.0.0",
    "ink-progress-bar": "^3.0.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-table": "^3.1.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.1",
    "meow": "^14.0.0",
    "node-pty": "^1.0.0",
    "react": "^19.1.1",
    "strip-ansi": "^7.1.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@jest/globals": "^30.2.0",
    "@types/dockerode": "^4.0.1",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.9",
    "@types/react": "^19.1.13",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "^30.2.0",
    "chalk": "^5.4.1",
    "ink-testing-library": "^4.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^28.1.0",
    "react-dom": "^19.1.1",
    "react-test-renderer": "^19.2.4",
    "ts-jest": "^29.4.6",
    "tsx": "^4.6.2",
    "typescript": "^5.9.2"
  }
}