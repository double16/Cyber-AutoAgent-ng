# Dockerfile for Cyber-AutoAgent tools base image (Kali Rolling base)
# syntax=docker/dockerfile:1.7

ARG APT_PROXY

FROM --platform=$BUILDPLATFORM golang:1.26 AS gobuild
ARG TARGETARCH
ARG BUILDPLATFORM
ENV DEBIAN_FRONTEND=noninteractive
ENV GOOS=linux GOARCH=$TARGETARCH
COPY docker/apt_proxy_configure.sh /tmp/
RUN /tmp/apt_proxy_configure.sh && \
    apt-get update && apt-get install -y --no-install-recommends build-essential pkg-config git ca-certificates &&\
    if [ "$BUILDPLATFORM" = "linux/amd64" ]; then apt-get install -y --no-install-recommends gcc-aarch64-linux-gnu g++-aarch64-linux-gnu libc6-dev-arm64-cross; fi &&\
    if [ "$BUILDPLATFORM" = "linux/arm64" ]; then apt-get install -y --no-install-recommends gcc-x86-64-linux-gnu g++-x86-64-linux-gnu libc6-dev-amd64-cross; fi
ENV CGO_ENABLED=1
ADD docker/packages-go.sh /tmp
RUN --mount=type=cache,target=/usr/local/share/go-build-cache --mount=type=cache,target=/usr/local/share/go \
    /tmp/packages-go.sh

FROM --platform=$BUILDPLATFORM ubuntu:26.04 AS cargobuild
ARG TARGETARCH
ARG BUILDPLATFORM
ENV DEBIAN_FRONTEND=noninteractive
COPY docker/apt_proxy_configure.sh /tmp/
RUN /tmp/apt_proxy_configure.sh
# scripts are separate to help with caching
ADD docker/setup-cargo.sh /tmp
RUN /tmp/setup-cargo.sh
ADD docker/packages-cargo.sh /tmp
RUN --mount=type=cache,target=/usr/local/share/cargo \
    /tmp/packages-cargo.sh

FROM kalilinux/kali-rolling

LABEL org.opencontainers.image.title="Cyber-AutoAgent-ng Tools"
LABEL org.opencontainers.image.description="Autonomous AI agent for ethical security assessments"
LABEL org.opencontainers.image.version="0.9.0"
LABEL org.opencontainers.image.source="https://github.com/double16/Cyber-AutoAgent-ng"
LABEL org.opencontainers.image.url="https://github.com/double16/Cyber-AutoAgent-ng"
LABEL org.opencontainers.image.licenses="MIT"
LABEL org.opencontainers.image.authors="github.com/double16"
LABEL org.opencontainers.image.vendor="github.com/double16"
LABEL org.opencontainers.image.revision=""

ENV DEBIAN_FRONTEND=noninteractive

RUN echo 'path-exclude=/usr/share/doc/*'        >  /etc/dpkg/dpkg.cfg.d/excludes &&\
    echo 'path-exclude=/usr/share/man/*'        >> /etc/dpkg/dpkg.cfg.d/excludes &&\
    echo 'path-exclude=/usr/share/groff/*'      >> /etc/dpkg/dpkg.cfg.d/excludes &&\
    echo 'path-exclude=/usr/share/info/*'       >> /etc/dpkg/dpkg.cfg.d/excludes &&\
    echo 'path-exclude=/usr/share/lintian/*'    >> /etc/dpkg/dpkg.cfg.d/excludes &&\
    echo 'path-include=/usr/share/doc/*/copyright' >> /etc/dpkg/dpkg.cfg.d/excludes

COPY docker/apt_proxy_configure.sh docker/apt_proxy_clean.sh /tmp/

RUN set -eux; \
    touch /root/.hushlogin && \
    /tmp/apt_proxy_configure.sh && \
    mirrors="ftp.acc.umu.se/mirror/kali.org/kali mirror.math.princeton.edu/pub/kali kali.mirror.garr.it/mirrors/kali mirror.pit.teraswitch.com/kali"; \
    success=0; \
    for mirror in $mirrors; do \
        echo "deb http://$mirror kali-rolling main contrib non-free non-free-firmware" > /etc/apt/sources.list; \
        if apt update; then \
            echo "Using Kali mirror: $mirror"; \
            success=1; \
            break; \
        fi; \
    done; \
    if [ "$success" -ne 1 ]; then \
        echo "ERROR: apt update failed for all configured mirrors" >&2; \
        exit 1; \
    fi;

RUN set -eux; \
    apt install -y --no-install-recommends \
    clang \
    python3 \
    python3-venv \
    python3-pip \
    python-is-python3 \
    pipx \
    python3-requests \
    python3-aiohttp \
    python3-jinja2 \
    python3-httpx \
    python3-ratelimit \
    python3-pwntools \
    python3-dotenv \
    sqlite3 \
    python2 \
    virtualenv \
    php \
    openssh-client \
    sshpass \
    # Java runtime for ZAP/Burp
    openjdk-21-jre-headless \
    # Binary analysis tools
    binutils \
    # Security tools
    nmap \
    sqlmap \
    curl \
    netcat-traditional \
    tcpdump \
    git \
    perl \
    gnupg2 \
    wget \
    # Perl SSL/TLS modules for Nikto HTTPS support
    libnet-ssleay-perl \
    libio-socket-ssl-perl \
    libcrypt-ssleay-perl \
    libssl-dev \
    ca-certificates \
    # RsaCtfTool (RSA Attacks) deps
    libgmp-dev libmpfr-dev libmpc-dev \
    # Network tools
    iputils-ping \
    dnsutils \
    iproute2 \
    net-tools \
    traceroute \
    openvpn \
    tshark \
    # Additional essential tools
    jq \
    yq \
    unzip \
    unrar \
    tree \
    sudo \
    file \
    xxd \
    # Web scanners
    nikto \
    whatweb \
    wafw00f \
    zaproxy \
    # Recon and DNS
    amass \
    subfinder \
    dnsrecon \
    dnsenum \
    theharvester \
    # Web fuzzing & directories
    ffuf \
    dirb \
    arjun \
    wapiti \
    wfuzz \
    wpscan \
    wordlists \
    # Network scanning
    masscan \
    naabu \
    # SMB/NetBIOS
    smbclient \
    smbmap \
    netexec \
    nbtscan \
    python3-impacket \
    responder \
    # SNMP/Discovery
    arp-scan \
    ike-scan \
    onesixtyone \
    snmpcheck \
    netdiscover \
    # Utilities
    hping3 \
    socat \
    proxychains4 \
    sslscan \
    seclists \
    # Web app helpers
    commix \
    hashid \
    html2text \
    # ProjectDiscovery vuln scanner
    nuclei \
    # Auth/bruteforce
    hydra \
    ncrack \
    hashcat \
    john \
    # Content and metadata
    libimage-exiftool-perl \
    cewl \
    # WebDAV testing
    davtest \
    # SSL/TLS testing
    testssl.sh \
    # Extra recon/webapp scanners
    gospider \
    httprobe \
    subjack \
    knockpy \
    joomscan \
    dirsearch \
    enum4linux \
    # Offensive frameworks
    metasploit-framework \
    # Go toolchain for ProjectDiscovery/tomnomnom tools
    golang \
    # Rust toolchain for building Python packages with native extensions
    rustc \
    cargo \
    # Node.js for GraphQL tools
    nodejs \
    npm \
    # Python build tools for pip packages
    python3-dev \
    build-essential \
    # Dependencies for pwntools/unicorn
    cmake \
    pkg-config \
    libglib2.0-dev \
    libffi-dev \
    libxml2-dev \
    libxslt1-dev \
    zlib1g-dev \
    # Binary Exploitation & Reversing
    gdb \
    ltrace \
    strace \
    radare2 \
    # Steganography & Forensics
    steghide \
    binwalk \
    foremost \
    # Ruby for zsteg/whatweb
    ruby-full && \
    apt clean && rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

# Provide symlinks from Ruby vendor_ruby so WhatWeb runs without error
RUN set -eux; \
    if command -v whatweb >/dev/null 2>&1; then \
      mkdir -p /usr/bin/lib; \
      # Link all vendor_ruby top-level files
      if ls /usr/lib/ruby/vendor_ruby/*.rb >/dev/null 2>&1; then \
        ln -sf /usr/lib/ruby/vendor_ruby/*.rb /usr/bin/lib/; \
      fi; \
    fi

# Install Python packages for our new tools (use --break-system-packages for Kali)
RUN pip3 install --break-system-packages pycryptodomex

# Install uv for fast dependency management
COPY --from=ghcr.io/astral-sh/uv:0.9.25 /uv /usr/local/bin/uv

# Install Ruby gems
RUN gem install zsteg

# JWT Tool - JWT analysis and manipulation
RUN git clone --depth=1 https://github.com/ticarpi/jwt_tool.git /opt/jwt_tool && \
    if [ -f /opt/jwt_tool/requirements.txt ]; then \
      cd /opt/jwt_tool && \
      python3 -m venv venv && \
      . venv/bin/activate && \
      pip install -r requirements.txt; \
    fi && \
    chmod +x /opt/jwt_tool/jwt_tool.py && \
    echo '#!/bin/bash\ncd /opt/jwt_tool && source venv/bin/activate && exec python3 /opt/jwt_tool/jwt_tool.py "$@"' > /usr/local/bin/jwt-tool && \
    chmod +x /usr/local/bin/jwt-tool

# SSTImap - Server-Side Template Injection scanner
RUN git clone --depth=1 https://github.com/vladko312/SSTImap.git /opt/sstimap && \
    if [ -f /opt/sstimap/requirements.txt ]; then \
      cd /opt/sstimap && \
      python3 -m venv venv && \
      . venv/bin/activate && \
      pip install -r requirements.txt; \
    fi && \
    chmod +x /opt/sstimap/sstimap.py && \
    echo '#!/bin/bash\ncd /opt/sstimap && source venv/bin/activate && exec python3 /opt/sstimap/sstimap.py "$@"' > /usr/local/bin/sstimap && \
    chmod +x /usr/local/bin/sstimap

# IDOR-Forge - IDOR scanner
RUN git clone --depth=1 https://github.com/errorfiathck/IDOR-Forge.git /opt/idor_forge && \
    if [ -f /opt/idor_forge/requirements.txt ]; then \
      cd /opt/idor_forge && \
      python3 -m venv venv && \
      . venv/bin/activate && \
      cat requirements.txt | tr -s '[:space:]' '\n' | grep -vi pyqt > reqs.txt && \
      pip install -r reqs.txt; \
    fi && \
    chmod +x /opt/idor_forge/IDOR-Forge.py && \
    echo '#!/bin/bash\ncd /opt/idor_forge && source venv/bin/activate && exec python3 /opt/idor_forge/IDOR-Forge.py "$@"' > /usr/local/bin/idor-forge && \
    chmod +x /usr/local/bin/idor-forge

# Gopherus - SSRF payload generator
RUN git clone --depth=1 https://github.com/tarunkant/Gopherus.git /opt/gopherus && \
    if [ -f /opt/gopherus/gopherus.py ]; then chmod +x /opt/gopherus/gopherus.py; fi && \
    echo '#!/bin/bash\nexec python2 /opt/gopherus/gopherus.py "$@"' > /usr/local/bin/gopherus && \
    chmod +x /usr/local/bin/gopherus

# PHPGGC - PHP Generic Gadget Chains
RUN git clone --depth=1 https://github.com/ambionics/phpggc.git /opt/phpggc && \
    chmod +x /opt/phpggc/phpggc && \
    ln -sf /opt/phpggc/phpggc /usr/local/bin/phpggc

# Ysoserial - Java Deserialization (download jar)
RUN mkdir -p /opt/ysoserial && \
    wget -qO /opt/ysoserial/ysoserial.jar https://github.com/frohoff/ysoserial/releases/latest/download/ysoserial-all.jar && \
    echo '#!/bin/bash\nexec java -jar /opt/ysoserial/ysoserial.jar "$@"' > /usr/local/bin/ysoserial && \
    chmod +x /usr/local/bin/ysoserial

# Install Evil-WinRM via gem
RUN gem install evil-winrm

# Install PEASS-ng (Privilege Escalation)
RUN mkdir -p /opt/peass && \
    wget -qO /opt/peass/linpeas.sh https://github.com/peass-ng/PEASS-ng/releases/latest/download/linpeas.sh && \
    chmod +x /opt/peass/linpeas.sh && \
    ln -sf /opt/peass/linpeas.sh /usr/local/bin/linpeas

# Install BloodHound Python (AD Analysis)
RUN pipx install --global bloodhound && \
    # Install Certipy (AD CS Abuse)
    pipx install --global certipy-ad && \
    # Install Coercer (AD Coercion)
    pipx install --global coercer && \
    pipx install --global ropgadget && \
    pipx install --global ropper && \
    # GraphQL Clairvoyance - GraphQL schema enumeration
    pipx install --global clairvoyance && \
    pipx install --global xsstrike && \
    pipx install --global lfimap-ng && \
    # Install Volatility3 (Memory Forensics) - Optional
    pipx install --global volatility3 && \
    # Install PwnCat-CS (Advanced Reverse Shell Handler)
    pipx install --global --python 3.11 --fetch-missing-python --preinstall 'setuptools<81' pwncat-cs && \
    # Install paramspider (Mining URLs from dark corners of Web Archives for bug hunting/fuzzing/further probing)
    pipx install --global git+https://github.com/devanshbatham/paramspider.git && \
    # Install RsaCtfTool (RSA Attacks) - requires GMP/MPFR libraries (installed above)
    pipx install --global git+https://github.com/RsaCtfTool/RsaCtfTool.git

# Install opengrep (fork of semgrep that is more open)
RUN ARCH=$(uname -m) && \
    if [ "$ARCH" = "x86_64" ]; then OPENGREP_ARCH="x86"; else OPENGREP_ARCH="${ARCH}"; fi && \
    OPENGREP_VERSION=$(curl -s https://api.github.com/repos/opengrep/opengrep/releases/latest | grep "tag_name" | cut -d ":" -f 2 | tr -d " ,\"") && \
    curl -L "https://github.com/opengrep/opengrep/releases/download/${OPENGREP_VERSION}/opengrep_manylinux_${OPENGREP_ARCH}" -o /usr/local/bin/opengrep && \
    chmod +x /usr/local/bin/opengrep

RUN npm install --global @graphql-inspector/cli

# Install TruffleHog (Secret Scanning)
RUN curl -sSfL https://raw.githubusercontent.com/trufflesecurity/trufflehog/main/scripts/install.sh latest | sh -s -- -b /usr/local/bin

# Install GitTools (Git Dumper/Extractor)
RUN git clone --depth=1 https://github.com/internetwache/GitTools.git /opt/gittools && \
    chmod +x /opt/gittools/Dumper/gitdumper.sh /opt/gittools/Extractor/extractor.sh && \
    ln -sf /opt/gittools/Dumper/gitdumper.sh /usr/local/bin/gitdumper && \
    ln -sf /opt/gittools/Extractor/extractor.sh /usr/local/bin/gitextractor

# Install Corsy (Scan for CORS misconfigurations)
# Replace with https://github.com/omranisecurity/CorsOne
RUN git clone --depth=1 --depth=1 https://github.com/s0md3v/Corsy.git /opt/corsy && \
    if [ -f /opt/corsy/requirements.txt ]; then \
      cd /opt/corsy && \
      python3 -m venv venv && \
      . venv/bin/activate && \
      pip install -r requirements.txt; \
    fi && \
    chmod +x /opt/corsy/corsy.py && \
    echo '#!/bin/bash\ncd /opt/corsy && source venv/bin/activate && exec python3 /opt/corsy/corsy.py "$@"' > /usr/local/bin/corsy && \
    chmod +x /usr/local/bin/corsy

COPY --from=gobuild /usr/local/bin/* /usr/local/bin/
COPY --from=cargobuild /usr/local/bin/* /usr/local/bin/

RUN useradd --create-home --shell /bin/bash cyberagent && \
    usermod -aG sudo cyberagent && \
    echo 'cyberagent ALL=(ALL) NOPASSWD: ALL' >> /etc/sudoers && \
    mkdir -p /app/evidence /app/logs /home/cyberagent/go && \
    chmod 755 /app/evidence /app/logs && \
    chown -R cyberagent:cyberagent /home/cyberagent/go

RUN mkdir -p -m 0700 "/root/.ssh" && touch "/root/.ssh/config" && chmod 0600 "/root/.ssh/config" && \
    echo "StrictHostKeyChecking no\nUserKnownHostsFile /dev/null\nBatchMode yes\n" >> "/root/.ssh/config" && \
    mkdir -p -m 0700 "/home/cyberagent/.ssh" && touch "/home/cyberagent/.ssh/config" && chmod 0600 "/home/cyberagent/.ssh/config" && \
    echo "StrictHostKeyChecking no\nUserKnownHostsFile /dev/null\nBatchMode yes\n" >> "/home/cyberagent/.ssh/config"

# Install Sliver (C2 Framework - Client only) - Optional, may fail on ARM64
RUN mkdir -p /home/cyberagent/sliver && \
    cd /home/cyberagent/sliver && \
    apt update &&\
    ( curl --silent https://sliver.sh/install | bash || true ) && \
    chown -R cyberagent:cyberagent /home/cyberagent/sliver && \
    apt clean && rm -rf /var/lib/apt/lists/*

# Load amass data (optional)
RUN amass -h || true

# Validate expected tools are present in the PATH
COPY docker/tools_check.sh src/modules/config/system/environment.yaml /tmp
RUN bash /tmp/tools_check.sh 2>&1 | tee /var/log/tools_check.log && \
    /tmp/apt_proxy_clean.sh && \
    rm -rf /tmp/* /var/tmp/*
